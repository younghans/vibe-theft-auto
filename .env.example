PORT=2567
DATABASE_URL=
DATABASE_POOL_MAX=2
DATABASE_POOL_IDLE_TIMEOUT_MS=30000
DATABASE_POOL_CONNECTION_TIMEOUT_MS=10000
WORLD_KEY=primary
WORLD_LAYOUT_SEED_PATH=server/data/world-layout.json
# Optional hosted websocket address override, without protocol.
# Example for a custom Colyseus Cloud backend domain: us-atl-06d422c8.vibetheftauto.xyz/2567
COLYSEUS_PUBLIC_ADDRESS=
# Frontend build-time backend URL. Set this for every static frontend host.
# Example: wss://us-atl-06d422c8.vibetheftauto.xyz
VTA_SERVER_URL=
# Public Supabase auth config. Used by the browser for sign-in and by the server to verify tokens.
# Never put service-role keys in frontend env.
VTA_SUPABASE_URL=
VTA_SUPABASE_PUBLISHABLE_KEY=
# Optional local file-mode override when DATABASE_URL is unset.
WORLD_LAYOUT_PATH=server/data/world-layout.json
# Production safety valve only. Prefer DATABASE_URL in production.
WORLD_PERSISTENCE_ALLOW_FILE_FALLBACK=false
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_NPC_MODEL=gpt-5.4-mini
OPENAI_TIMEOUT_MS=12000
# Optional comma-separated admin keys for privileged tools like world building.
ADMIN_KEYS=
