{
  "name": "stickrpg",
  "version": "1.0.0",
  "type": "module",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "npm run dev:stack",
    "dev:client": "node scripts/dev-server.mjs . 4173 --live-reload",
    "dev:client:worktree": "node scripts/dev-server.mjs . 4273 ws://localhost:2667 --live-reload",
    "dev:server": "node --watch server/index.mjs",
    "dev:server:worktree": "node --watch server/index.mjs 2667",
    "dev:stack": "concurrently \"npm:dev:client\" \"npm:dev:server\"",
    "dev:worktree": "concurrently \"npm:dev:client:worktree\" \"npm:dev:server:worktree\"",
    "world:inspect": "node scripts/world-snapshot-tool.mjs inspect",
    "world:remove-placement": "node scripts/world-snapshot-tool.mjs remove-placement",
    "world:copy": "node scripts/copy-world-snapshot.mjs",
    "world:copy:primary-to-staging": "node scripts/copy-world-snapshot.mjs primary staging",
    "world:promote:staging-to-primary": "node scripts/copy-world-snapshot.mjs staging primary",
    "start": "node server/start-production.mjs",
    "prebuild": "npm run optimize:assets",
    "build": "node scripts/build-web.mjs",
    "optimize:assets": "node scripts/optimize-mixamo-assets.mjs",
    "optimize:assets:startup": "node scripts/optimize-mixamo-assets.mjs --startup-only",
    "deploy:colyseus": "npx @colyseus/cloud deploy",
    "generate:bar-building": "node scripts/generate-bar-building.mjs",
    "generate:gym-building": "node scripts/generate-gym-building.mjs",
    "generate:gym-building-large": "node scripts/generate-gym-building-large.mjs",
    "inspect:buildings": "node scripts/inspect-building-assets.mjs",
    "preview": "node scripts/dev-server.mjs dist 4174",
    "validate": "node scripts/validate-world-editor.mjs",
    "validate:portraits": "node scripts/validate-npc-portraits.mjs",
    "validate:mixamo": "node scripts/validate-mixamo-assets.mjs \"assets/mixamo/characters/x-bot.fbx\" \"assets/mixamo/animations/walking.json\"",
    "extract:mixamo-animation": "node scripts/extract-fbx-animation.mjs \"assets/mixamo/animations/walking.fbx\" \"assets/mixamo/animations/walking.json\" Walking"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "@gltf-transform/cli": "^4.3.0",
    "@gltf-transform/core": "^4.3.0",
    "@gltf-transform/functions": "^4.3.0",
    "@colyseus/schema": "^4.0.19",
    "@colyseus/sdk": "^0.17.35",
    "@colyseus/ws-transport": "^0.17.9",
    "colyseus": "^0.17.8",
    "concurrently": "^9.2.1",
    "esbuild": "^0.28.0",
    "fbx2gltf": "^0.9.7-p1",
    "openai": "^6.33.0",
    "pg": "^8.20.0",
    "three": "^0.183.2"
  },
  "devDependencies": {}
}
