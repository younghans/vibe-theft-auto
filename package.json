{
  "name": "vibe-theft-auto",
  "version": "1.0.0",
  "description": "A browser-based multiplayer city game built with Three.js and Colyseus.",
  "type": "module",
  "packageManager": "npm@10.9.0",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "npm run dev:stack",
    "dev:client": "node scripts/dev-server.mjs . 4173 --live-reload",
    "dev:client:worktree": "node scripts/dev-server.mjs . 4273 ws://localhost:2667 --live-reload",
    "dev:server": "node --watch server/index.mjs",
    "dev:server:worktree": "node --watch server/index.mjs 2667",
    "dev:stack": "concurrently \"npm:dev:client\" \"npm:dev:server\"",
    "dev:worktree": "concurrently \"npm:dev:client:worktree\" \"npm:dev:server:worktree\"",
    "world:inspect": "node scripts/world-snapshot-tool.mjs inspect",
    "world:remove-placement": "node scripts/world-snapshot-tool.mjs remove-placement",
    "world:copy": "node scripts/copy-world-snapshot.mjs",
    "world:copy:primary-to-staging": "node scripts/copy-world-snapshot.mjs primary staging",
    "world:promote:staging-to-primary": "node scripts/copy-world-snapshot.mjs staging primary",
    "db:sync:render-to-supabase": "node scripts/sync-render-postgres-to-supabase.mjs",
    "start": "node server/start-production.mjs",
    "build": "npm run build:server",
    "build:all": "npm run build:web && npm run build:server",
    "build:web": "node scripts/build-web.mjs",
    "build:server": "node --check server/index.mjs && node --check server/app.config.js && node --check server/src/worldPersistence.js && node --check server/src/playerSnapshots.js && node --check server/src/playerAccounts.js && node --check server/src/supabaseAuth.js && node --check server/src/stockMarketPersistence.js && node --check server/src/NpcChatEngine.js && node --check server/src/WorldRoom.js",
    "worker:prod": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/start-agent-worker-prod.ps1",
    "worker:prod:bg": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/start-agent-worker-prod-detached.ps1",
    "worker:prod:once": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/start-agent-worker-prod.ps1 -Once",
    "worker:prod:auto": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/start-agent-worker-prod.ps1 -AutoDeploy",
    "worker:prod:auto:bg": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/start-agent-worker-prod-detached.ps1 -AutoDeploy",
    "worker:prod:check": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/start-agent-worker-prod.ps1 -Check",
    "worker:drain": "node scripts/agent-worker-control.mjs drain",
    "worker:drain:deploy": "node scripts/agent-worker-control.mjs drain-deploy",
    "worker:resume": "node scripts/agent-worker-control.mjs resume",
    "worker:status": "node scripts/agent-worker-control.mjs status",
    "wavedash:dev": "npm run build:web && wavedash dev",
    "deploy:wavedash": "npm run build:web && wavedash build push",
    "optimize:assets": "npm --prefix tools/mixamo-optimizer install && npm --prefix tools/mixamo-optimizer run optimize --",
    "optimize:assets:startup": "npm --prefix tools/mixamo-optimizer install && npm --prefix tools/mixamo-optimizer run optimize -- --startup-only",
    "deploy:colyseus": "node scripts/deploy-colyseus-noninteractive.mjs",
    "generate:bar-building": "node scripts/generate-bar-building.mjs",
    "generate:district-buildings": "node scripts/generate-district-buildings.mjs",
    "generate:gym-building": "node scripts/generate-gym-building.mjs",
    "generate:gym-building-large": "node scripts/generate-gym-building-large.mjs",
    "generate:police-station": "node scripts/generate-police-station-building.mjs",
    "generate:police-vehicle": "node scripts/generate-low-poly-police-vehicle.mjs",
    "inspect:buildings": "node scripts/inspect-building-assets.mjs",
    "preview": "node scripts/dev-server.mjs dist 4174",
    "validate": "node scripts/validate-world-editor.mjs",
    "validate:all": "npm run validate && npm run validate:movement && npm run validate:phone-apps && npm run validate:account-saves && npm run validate:skills && npm run validate:npc-dialogue && npm run validate:agent-tasks && npm run validate:world-backups && npm run validate:blackjack && npm run validate:computer-activity && npm run validate:portraits && npm run validate:mixamo",
    "validate:movement": "node scripts/validate-movement-transport.mjs",
    "validate:phone-apps": "node scripts/validate-phone-apps.mjs",
    "validate:account-saves": "node scripts/validate-account-saves.mjs",
    "validate:auth-rollout": "node scripts/validate-auth-rollout.mjs",
    "validate:skills": "node scripts/validate-skills.mjs",
    "validate:npc-dialogue": "node scripts/validate-npc-dialogue.mjs",
    "validate:agent-tasks": "node scripts/validate-agent-tasks.mjs",
    "validate:world-backups": "node scripts/validate-world-backups.mjs",
    "validate:blackjack": "node scripts/validate-blackjack.mjs",
    "validate:computer-activity": "node scripts/validate-computer-activity.mjs",
    "validate:portraits": "node scripts/validate-npc-portraits.mjs",
    "validate:mixamo": "node scripts/validate-mixamo-assets.mjs \"assets/runtime/mixamo/characters/xBot.glb\" \"assets/mixamo/animations/walking.json\"",
    "extract:mixamo-animation": "node scripts/extract-fbx-animation.mjs \"assets/source/mixamo/animations/walking.fbx\" \"assets/mixamo/animations/walking.json\" Walking",
    "public:export": "node scripts/create-public-export.mjs"
  },
  "keywords": [
    "threejs",
    "colyseus",
    "multiplayer",
    "browser-game",
    "vibe-theft-auto"
  ],
  "author": "oldfeet (https://x.com/oldfeet)",
  "license": "ISC",
  "homepage": "https://www.vibetheftauto.xyz/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/younghans/vibe-theft-auto.git"
  },
  "bugs": {
    "url": "https://github.com/younghans/vibe-theft-auto/issues"
  },
  "dependencies": {
    "@colyseus/core": "^0.17.43",
    "@colyseus/schema": "^4.0.19",
    "@colyseus/sdk": "^0.17.35",
    "@colyseus/tools": "^0.17.19",
    "@colyseus/ws-transport": "^0.17.9",
    "@supabase/supabase-js": "^2.106.0",
    "concurrently": "^9.2.1",
    "dotenv": "^17.4.2",
    "esbuild": "^0.28.0",
    "openai": "^6.38.0",
    "pg": "^8.20.0",
    "three": "^0.183.2"
  }
}
